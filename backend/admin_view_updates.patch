---

Add this JavaScript before the charts() function:

function openMedicalRecord(bookingId, event) {
  // Prevent if clicking on select/dropdown
  if (event.target.tagName === 'SELECT' || event.target.closest('select')) {
    return;
  }
  const row = event.currentTarget;
  // Single click opens medical records in new tab after delay
  if (row._clickTimer) {
    clearTimeout(row._clickTimer);
    row._clickTimer = null;
    return; // This is a double-click, don't open
  }
  row._clickTimer = setTimeout(() => {
    row._clickTimer = null;
    const medicalRecordsUrl = window.location.origin + '/admin/medical-records?booking_id=' + bookingId;
    window.open(medicalRecordsUrl, '_blank', 'width=1400,height=900');
  }, 300);
}

function toggleFlip(event) {
  event.stopPropagation();
  const row = event.currentTarget;
  if (row._clickTimer) {
    clearTimeout(row._clickTimer);
    row._clickTimer = null;
  }
  row.classList.toggle('flipped');
}

